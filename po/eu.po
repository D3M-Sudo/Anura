#: ../data/com.github.d3msudo.anura.metainfo.xml.in:9
msgid "Anura is an intuitive text extraction tool (OCR) designed for the GNOME desktop. It allows you to quickly grab text from any source on your screen, including videos, PDFs, images, or protected web pages."
msgstr ""

#: ../data/com.github.d3msudo.anura.metainfo.xml.in:14
msgid "Key features include:"
msgstr ""

#: ../data/com.github.d3msudo.anura.metainfo.xml.in:16
msgid "High-accuracy OCR powered by Tesseract."
msgstr ""

#: ../data/com.github.d3msudo.anura.metainfo.xml.in:17
msgid "Built-in QR code decoding and link following."
msgstr ""

#: ../data/com.github.d3msudo.anura.metainfo.xml.in:18
msgid "Support for multiple languages with on-demand model download."
msgstr ""

#: ../data/com.github.d3msudo.anura.metainfo.xml.in:19
msgid "Privacy-focused: no telemetry and no anonymous data collection."
msgstr ""

#: ../data/com.github.d3msudo.anura.metainfo.xml.in:20
msgid "Modern GTK4 / Libadwaita interface following GNOME Human Interface Guidelines."
msgstr ""

#: ../data/com.github.d3msudo.anura.metainfo.xml.in:22
msgid "Network access is used exclusively to download Tesseract OCR language models on demand and for the optional text-to-speech feature (Google TTS). No user data is ever transmitted."
msgstr ""

#: ../data/com.github.d3msudo.anura.metainfo.xml.in:31
msgid "Main interface showing the text extraction screen (dark theme)"
msgstr ""

#: ../data/com.github.d3msudo.anura.metainfo.xml.in:35
msgid "Extracted text displayed after OCR recognition"
msgstr ""

