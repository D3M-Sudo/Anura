<?xml version="1.0" encoding="UTF-8"?>
<schemalist gettext-domain="anura">
  <schema id="com.github.d3msudo.anura" path="/com/github/d3msudo/anura/">
    
    <key name="window-width" type="i">
      <default>-1</default>
      <summary>Default window width</summary>
    </key>
    <key name="window-height" type="i">
      <default>-1</default>
      <summary>Default window height</summary>
    </key>

    <key name="extra-language" type="s">
      <default>""</default>
      <summary>Secondary OCR language</summary>
      <description>Optional secondary language for text extraction. Leave empty to disable.</description>
    </key>
    <key name="active-language" type="s">
      <default>"eng"</default>
      <summary>Primary language</summary>
      <description>Primary language for text extraction.</description>
    </key>

    <key name="autocopy" type="b">
      <default>true</default>
      <summary>Autocopy text to clipboard</summary>
      <description>Automatically copy the extracted text to the clipboard.</description>
    </key>
    <key name="autolinks" type="b">
      <default>false</default>
      <summary>Auto-open detected links</summary>
      <description>Automatically open URLs found in extracted text.</description>
    </key>

    <key name="tts-volume" type="d">
      <default>1.0</default>
      <range min="0.0" max="1.0"/>
      <summary>TTS Volume</summary>
      <description>Volume level for text-to-speech playback (0.0 to 1.0).</description>
    </key>

    <key name="tts-language" type="s">
      <default>""</default>
      <summary>TTS Language</summary>
      <description>Language code for text-to-speech. Empty means use the active OCR language.</description>
    </key>
  </schema>
</schemalist>