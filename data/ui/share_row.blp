using Gtk 4.0;

template $ShareRow : ListBoxRow {
  GestureClick row_click {
    button: 1;
    released => $_on_released();
  }

  activate => $_on_released();

  Box box {
    spacing: 6;

    Image image {
      icon-size: normal;
    }

    Label label {
      halign: start;
    }
  }
}
