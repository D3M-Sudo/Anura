<?xml version="1.0" encoding="UTF-8"?>
<interface domain="velis">
  <requires lib="gtk" version="4.0"/>
  <template class="PreferencesDialog" parent="AdwPreferencesDialog">
    <property name="title" translatable="true">Preferences</property>
    <child>
      <object class="AdwPreferencesPage">
        <property name="title" translatable="true">General</property>
        <property name="icon-name">settings-symbolic</property>
        <child>
          <object class="AdwPreferencesGroup">
            <property name="title" translatable="true">OCR</property>
            <child>
              <object class="AdwComboRow" id="language_row">
                <property name="title" translatable="true">Default Language</property>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
    <child>
      <object class="AdwPreferencesPage">
        <property name="title" translatable="true">Translation</property>
        <property name="icon-name">web-browser-symbolic</property>
        <child>
          <object class="AdwPreferencesGroup">
            <child>
              <object class="AdwEntryRow" id="translate_endpoint_row">
                <property name="title" translatable="true">LibreTranslate Endpoint</property>
              </object>
            </child>
            <child>
              <object class="AdwPasswordEntryRow" id="translate_api_key_row">
                <property name="title" translatable="true">API Key (Optional)</property>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
  </template>
</interface>
