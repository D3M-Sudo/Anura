[Desktop Entry]
Name=Anura
GenericName=OCR Tool
Comment=Extract text from any image, video, or web page
Icon=com.github.d3msudo.anura
Exec=anura
Terminal=false
Type=Application
Categories=Graphics;Utility;
Keywords=OCR;Text;Extraction;Reader;QR;Scanner;
StartupNotify=true
DBusActivatable=false
Actions=extractToClipboard;

[Desktop Action extractToClipboard]
Name=Extract Text to Clipboard
Exec=anura --extract_to_clipboard
