{
    "app-id": "io.github.d3msudo.anura",
    "runtime": "org.gnome.Platform",
    "runtime-version": "50",
    "sdk": "org.gnome.Sdk",
    "command": "anura",
    "branch": "main",
    "separate-locales": false,
    "finish-args": [
        "--share=network",
        "--share=ipc",
        "--socket=x11",
        "--socket=wayland",
        "--socket=pulseaudio",
        "--device=dri",
        "--filesystem=xdg-pictures:ro",
        "--filesystem=xdg-download:ro",
        "--filesystem=xdg-desktop:ro",
        "--filesystem=xdg-documents:ro",
        "--talk-name=org.a11y.Bus",
        "--talk-name=org.freedesktop.portal.Desktop",
        "--env=TESSDATA_PREFIX=/app/share/tessdata"
    ],
    "cleanup": [
        "/include",
        "/lib/pkgconfig",
        "/share/aclocal",
        "/share/pkgconfig",
        "*.la",
        "*.a"
    ],
    "build-options": {
        "env": {
            "GI_TYPELIB_PATH": "/app/lib/girepository-1.0:/app/lib/x86_64-linux-gnu/girepository-1.0:/usr/lib/girepository-1.0",
            "LD_LIBRARY_PATH": "/app/lib:/app/lib/x86_64-linux-gnu",
            "TESSDATA_PREFIX": "/app/share/tessdata",
            "NO_AT_BRIDGE": "1",
            "GTK_A11Y": "none"
        }
    },
    "modules": [
        {
            "name": "leptonica",
            "buildsystem": "autotools",
            "cleanup": [
                "/bin"
            ],
            "config-opts": [
                "--disable-static",
                "--with-libpng",
                "--with-jpeg",
                "--with-libtiff",
                "--with-zlib"
            ],
            "post-install": [
                "install -Dm0644 leptonica-license.txt $FLATPAK_DEST/share/licenses/io.github.d3msudo.anura/leptonica/LICENSE"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/DanBloomberg/leptonica/releases/download/1.84.1/leptonica-1.84.1.tar.gz",
                    "sha256": "2b3e1254b1cca381e77c819b59ca99774ff43530209b9aeb511e1d46588a64f6",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 1549,
                        "stable-only": true,
                        "url-template": "https://github.com/DanBloomberg/leptonica/releases/download/$version/leptonica-$version.tar.gz"
                    }
                }
            ]
        },
        {
            "name": "python3-pybind11",
            "buildsystem": "simple",
            "build-commands": [
                "pip3 install --no-deps --no-build-isolation --prefix=/app .",
                "bash -c 'shopt -s nocaseglob; find /app/lib/python3.*/site-packages/pybind11-*.dist-info -type f -iname \"*icense*\" -exec install -Dm0644 {} $FLATPAK_DEST/share/licenses/io.github.d3msudo.anura/pybind11/LICENSE \\; -quit || true'"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://files.pythonhosted.org/packages/d2/c1/72b9622fcb32ff98b054f724e213c7f70d6898baa714f4516288456ceaba/pybind11-2.13.6.tar.gz",
