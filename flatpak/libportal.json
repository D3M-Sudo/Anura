{
    "name" : "libportal",
    "buildsystem" : "meson",
    "builddir" : true,
    "config-opts" : [
        "-Ddocs=false",
        "-Dtests=false",
        "-Dvapi=false",
        "-Dintrospection=true",
        "-Dgtk3=disabled",
        "-Dgtk4=enabled",
        "-Dqt5=disabled"
    ],
    "cleanup" : [
        "/include",
        "/lib/pkgconfig",
        "/share/gir-1.0",
        "*.la"
    ],
    "sources" : [
        {
            "type" : "git",
            "url" : "https://github.com/flatpak/libportal.git",
            "tag" : "0.9.1"
        }
    ]
}
