{
    "app-id": "com.github.d3msudo.anura",
    "runtime": "org.gnome.Platform",
    "runtime-version": "49",
    "sdk": "org.gnome.Sdk",
    "command": "anura",
    "x-ci-notes": "CI and production both aligned to GNOME 49 stable runtime",

    "finish-args": [
        "--share=network",
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--socket=pulseaudio",
        "--device=dri"
    ],

    "cleanup": [
        "/include",
        "/lib/pkgconfig",
        "/share/doc",
        "/share/man",
        "*.la",
        "*.a"
    ],

    "modules": [
        {
            "name": "leptonica",
            "config-opts": [
                "--disable-static",
                "--with-libpng",
                "--with-jpeg",
                "--with-libtiff",
                "--with-zlib"
            ],
            "cleanup": [ "/bin", "/include", "/lib/pkgconfig", "*.la" ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/DanBloomberg/leptonica.git",
                    "tag": "1.85.0",
                    "commit": "63aef18d98432b8582a1565e241f7bd2ee9cc8d9",
                    "x-checker-data": {
                        "type": "git",
                        "tag-pattern": "^([\\d.]+)$"
                    }
                }
            ]
        },

        {
            "name": "tesseract",
            "config-opts": [
                "--disable-static",
                "--disable-graphics",
                "--enable-legacy"
            ],
            "cleanup": [ "/include", "/lib/pkgconfig", "*.la" ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/tesseract-ocr/tesseract.git",
                    "tag": "5.5.0",
                    "commit": "64eab6c457b2337dd690746a5fde5c222b40d5f8",
                    "x-checker-data": {
                        "type": "git",
                        "tag-pattern": "^([\\d.]+)$"
                    }
                }
            ],
            "modules": [
                {
                    "name": "tessdata-fast",
                    "buildsystem": "simple",
                    "build-commands": [
                        "mkdir -p /app/share/tessdata",
                        "cp eng.traineddata ita.traineddata /app/share/tessdata/"
                    ],
                    "sources": [
                        {
                            "type": "file",
                            "_comment": "NOTE: This commit SHA is pinned during release via ./release.sh",
                            "url": "https://github.com/tesseract-ocr/tessdata_fast/raw/4767ea922bcc460e70b87b1d303ebdfed0e3060b/eng.traineddata",
                            "sha256": "7d4322bd2a7749724879683fc3912cb542f19906c83bcc1a52132556427170b2"
                        },
                        {
                            "type": "file",
                            "_comment": "NOTE: This commit SHA is pinned during release via ./release.sh",
                            "url": "https://github.com/tesseract-ocr/tessdata_fast/raw/4767ea922bcc460e70b87b1d303ebdfed0e3060b/ita.traineddata",
                            "sha256": "b8f89e1e785118dac4d51ae042c029a64edb5c3ee42ef73027a6d412748d8827"
                        }
                    ]
                }
            ]
        },

        {
            "name": "libportal",
            "buildsystem": "meson",
            "builddir": true,
            "config-opts": [
                "-Ddocs=false",
                "-Dtests=false",
                "-Dvapi=false",
                "-Dintrospection=true",
                "-Dbackend-gtk3=disabled",
                "-Dbackend-gtk4=enabled",
                "-Dbackend-qt5=disabled"
            ],
            "cleanup": [ "/include", "/lib/pkgconfig", "*.la" ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/flatpak/libportal.git",
                    "tag": "0.9.1",
                    "commit": "8f5dc8d192f6e31dafe69e35219e3b707bde71ce",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 193688,
                        "stable-only": true,
                        "tag-template": "$version"
                    }
                }
            ]
        },

        {
            "name": "zbar",
            "buildsystem": "autotools",
            "cleanup": [ "/bin", "/include", "/lib/pkgconfig", "*.la" ],
            "config-opts": [
                "--disable-static",
                "--without-gtk",
                "--without-python",
                "--without-imagemagick",
                "--without-dbus",
                "--without-qt",
                "--without-x",
                "--disable-video",
                "--disable-doc",
                "--with-introspection=no"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/mchehab/zbar.git",
                    "tag": "0.23.93",
                    "commit": "bb05ec54eec57f8397cb13fb9161372a281a1219",
                    "x-checker-data": {
                        "type": "git",
                        "tag-pattern": "^([\\d.]+)$"
                    }
                },
                {
                    "type": "shell",
                    "commands": [
                        "autoreconf -vfi",
                        "sed -i 's/lpthread/pthread/g' configure"
                    ]
                }
            ]
        },

        {
            "name": "blueprint-compiler",
            "buildsystem": "meson",
            "cleanup": [ "*" ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://gitlab.gnome.org/jwestman/blueprint-compiler.git",
                    "tag": "v0.16.0",
                    "commit": "04ef0944db56ab01307a29aaa7303df6067cb3c0",
                    "x-checker-data": {
                        "type": "git",
                        "tag-pattern": "^v([\\d.]+)$",
                        "tag-template": "v$version"
                    }
                }
            ]
        },

