{
    "app-id": "com.github.d3msudo.anura",
    "runtime": "org.gnome.Platform",
    "runtime-version": "49",
    "sdk": "org.gnome.Sdk",
    "command": "anura",
    "finish-args": [
        "--share=network",
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=dri",
        "--filesystem=xdg-run/dconf",
        "--filesystem=~/.config/dconf:ro",
        "--talk-name=org.gtk.vfs.*",
        "--own-name=org.gnome.gsettings"
    ],
    "cleanup": [
        "/include",
        "/lib/pkgconfig",
        "/share/doc",
        "/share/man",
        "*.la",
        "*.a"
    ],
    "modules": [
        {
            "name": "leptonica",
            "config-opts": [
                "--disable-static"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/DanBloomberg/leptonica.git",
                    "tag": "1.85.0"
                }
            ]
        },
        {
            "name": "tesseract",
            "config-opts": [
                "--disable-static",
                "--disable-graphics"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/tesseract-ocr/tesseract.git",
                    "tag": "5.5.0"
                }
            ],
            "modules": [
                {
                    "name": "tessdata-fast",
                    "buildsystem": "simple",
                    "build-commands": [
                        "mkdir -p /app/share/tessdata",
                        "cp eng.traineddata ita.traineddata /app/share/tessdata/"
                    ],
                    "sources": [
                        {
                            "type": "file",
                            "url": "https://github.com/tesseract-ocr/tessdata_fast/raw/main/eng.traineddata",
                            "sha256": "7d4322bd2a7749724879683fc3912cb542f19906c83bcc1a52132556427170b2"
                        },
                        {
                            "type": "file",
                            "url": "https://github.com/tesseract-ocr/tessdata_fast/raw/main/ita.traineddata",
                            "sha256": "b8f89e1e785118dac4d51ae042c029a64edb5c3ee42ef73027a6d412748d8827"
                        }
                    ]
                }
            ]
        },
        {
            "name": "libportal",
            "buildsystem": "meson",
            "config-opts": [
                "-Ddocs=false",
                "-Dtests=false",
                "-Dbackend-gtk4=enabled"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/flatpak/libportal.git",
                    "tag": "0.9.1"
                }
            ]
        },
        {
            "name": "zbar",
            "buildsystem": "autotools",
            "config-opts": [
                "--disable-static",
                "--without-gtk",
                "--without-python",
                "--without-imagemagick",
                "--disable-video"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/mchehab/zbar.git",
                    "tag": "0.23.93"
                },
                {
                    "type": "shell",
                    "commands": [
                        "autoreconf -vfi"
                    ]
                }
            ]
        },
        {
            "name": "python3-dependencies",
            "buildsystem": "simple",
            "build-commands": [
                "pip3 install --verbose --prefix=/app requests Pillow pytesseract gTTS python-dateutil"
            ]
        },
        {
            "name": "anura",
            "buildsystem": "meson",
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/D3M-Sudo/Anura.git",
                    "tag": "v0.1.2"
                }
            ]
        }
    ]
}
