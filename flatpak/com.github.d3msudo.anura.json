{
    "app-id" : "com.github.d3msudo.anura",
    "runtime" : "org.gnome.Platform",
    "runtime-version" : "47",
    "sdk" : "org.gnome.Sdk",
    "command" : "anura",
    "finish-args" : [
        "--share=network",
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=dri",
        "--talk-name=org.freedesktop.Notifications",
        "--talk-name=org.gnome.Shell.Screenshot",
        "--talk-name=org.kde.kspread.screenshot",
        "--filesystem=xdg-run/dconf",
        "--filesystem=~/.config/dconf:ro",
        "--talk-name=ca.desrt.dconf",
        "--env=DCONF_USER_CONFIG_DIR=.config/dconf"
    ],
    "cleanup" : [
        "/include",
        "/lib/pkgconfig",
        "/share/doc",
        "/share/man",
        "*.la",
        "*.a"
    ],
    "modules" : [
        {
            "name" : "blueprint-compiler",
            "buildsystem" : "meson",
            "cleanup" : [ "*" ],
            "sources" : [
                {
                    "type" : "git",
                    "url" : "https://gitlab.gnome.org/jwestman/blueprint-compiler.git",
                    "tag" : "v0.16.0"
                }
            ]
        },
        "leptonica.json",
        "tesseract.json",
        "libportal.json",
        "zbar.json",
        "python3-modules.json",
        "python3-gTTS.json",
        {
            "name" : "anura",
            "builddir" : true,
            "buildsystem" : "meson",
            "sources" : [
                {
                    "type" : "dir",
                    "path" : ".."
                }
            ]
        }
    ]
}