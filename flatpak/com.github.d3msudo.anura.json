{
    "app-id": "com.github.d3msudo.anura",
    "runtime": "org.gnome.Platform",
    "runtime-version": "50",
    "sdk": "org.gnome.Sdk",
    "command": "anura",
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=dri",
        "--filesystem=xdg-run/format-status:ro"
    ],
    "cleanup": [
        "/include",
        "/lib/pkgconfig",
        "/share/aclocal",
        "/share/pkgconfig",
        "*.la",
        "*.a"
    ],
    "modules": [
        {
            "name": "zbar",
            "buildsystem": "autotools",
            "cleanup": [
                "/bin"
            ],
            "config-opts": [
                "--disable-static",
                "--without-gtk",
                "--without-python",
                "--without-imagemagick",
                "--without-dbus",
                "--without-qt",
                "--without-x",
                "--disable-video",
                "--disable-doc",
                "--with-introspection=no"
            ],
            "post-install": [
                "install -Dm0644 LICENSE $FLATPAK_DEST/share/licenses/com.github.d3msudo.anura/zbar/LICENSE"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/mchehab/zbar.git",
                    "tag": "0.23.93",
                    "commit": "bb05ec54eec57f8397cb13fb9161372a281a1219",
                    "x-checker-data": {
                        "type": "git",
                        "tag-pattern": "^([\\d.]+)$"
                    }
                },
                {
                    "type": "patch",
                    "path": "zbar-fix-pthread.patch"
                },
                {
                    "type": "shell",
                    "commands": [
                        "autoreconf -vfi"
                    ]
                }
            ]
        },
        {
            "name": "libtiff",
            "cleanup": [
                "/share/doc",
                "/share/man"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://download.osgeo.org/libtiff/tiff-4.6.0.tar.gz",
                    "sha256": "eec014aa27d4fcaf7dc477e39dcdfa16d043c5deecab9bb2d631df2cfda1dcda"
                }
            ]
        },
        {
            "name": "leptonica",
            "buildsystem": "autotools",
            "cleanup": [
                "/bin"
            ],
            "config-opts": [
                "--with-libtiff",
                "--with-zlib"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/DanBloomberg/leptonica/releases/download/1.84.1/leptonica-1.84.1.tar.gz",
                    "sha256": "045aa639da2977f884bf6e9927702811d615309489f7fb0772f88a91b490f2b3"
                }
            ]
        },
        {
            "name": "tesseract",
            "buildsystem": "autotools",
            "cleanup": [
                "/bin",
                "/share/tessdata"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/tesseract-ocr/tesseract/archive/refs/tags/5.3.4.tar.gz",
                    "sha256": "9b6466f212f459ba4187ef3e69f8d5cb0ca124ee410df2db66bc64df93bfa097"
                }
            ]
        },
        {
            "name": "tessdata-ita",
            "buildsystem": "simple",
            "build-commands": [
                "install -Dm0644 ita.traineddata $FLATPAK_DEST/share/tessdata/ita.traineddata"
            ],
            "sources": [
                {
                    "type": "file",
                    "url": "https://github.com/tesseract-ocr/tessdata_fast/raw/main/ita.traineddata",
                    "sha256": "e30da65cb33a6839352e00b84df46da6e6329c29f860fb7731a57c5e2ec72ccf"
                }
            ]
        },
        {
            "name": "anura",
            "buildsystem": "meson",
            "sources": [
                {
                    "type": "dir",
                    "path": ".."
                }
            ]
        }
    ]
}
