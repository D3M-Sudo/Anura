        {
            "name": "anura",
            "builddir": true,
            "buildsystem": "meson",
            "build-options": {
                "env": {
                    "GI_TYPELIB_PATH": "/app/lib/girepository-1.0:/usr/lib/girepository-1.0",
                    "LD_LIBRARY_PATH": "/app/lib"
