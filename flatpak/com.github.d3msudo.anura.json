{
    "app-id": "com.github.d3msudo.anura",
    "runtime": "org.gnome.Platform",
    "runtime-version": "49",
    "sdk": "org.gnome.Sdk",
    "command": "anura",
    "x-ci-notes": "CI and production both aligned to GNOME 49 stable runtime",

    "finish-args": [
        "--share=network",
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--socket=pulseaudio",
        "--device=dri"
    ],

    "cleanup": [
        "/include",
        "/lib/pkgconfig",
        "/share/doc",
        "/share/man",
        "*.la",
        "*.a"
    ],

    "modules": [
        {
            "name": "leptonica",
            "config-opts": [
                "--disable-static",
                "--with-libpng",
                "--with-jpeg",
                "--with-libtiff",
                "--with-zlib"
            ],
            "cleanup": [ "/bin", "/include", "/lib/pkgconfig", "*.la" ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/DanBloomberg/leptonica.git",
                    "tag": "1.85.0",
                    "commit": "63aef18d98432b8582a1565e241f7bd2ee9cc8d9",
                    "x-checker-data": {
                        "type": "git",
                        "tag-pattern": "^([\\d.]+)$"
                    }
                }
            ]
        },

        {
            "name": "tesseract",
            "config-opts": [
                "--disable-static",
                "--disable-graphics",
                "--enable-legacy"
            ],
            "cleanup": [ "/include", "/lib/pkgconfig", "*.la" ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/tesseract-ocr/tesseract.git",
                    "tag": "5.5.0",
                    "commit": "64eab6c457b2337dd690746a5fde5c222b40d5f8",
                    "x-checker-data": {
                        "type": "git",
                        "tag-pattern": "^([\\d.]+)$"
                    }
                }
            ],
            "modules": [
                {
                    "name": "tessdata-fast",
                    "buildsystem": "simple",
                    "build-commands": [
                        "mkdir -p /app/share/tessdata",
                        "cp eng.traineddata ita.traineddata /app/share/tessdata/"
                    ],
                    "sources": [
                        {
                            "type": "file",
                            "_comment": "NOTE: This commit SHA is pinned during release via ./release.sh",
                            "url": "https://github.com/tesseract-ocr/tessdata_fast/raw/main/eng.traineddata",
                            "sha256": "7d4322bd2a7749724879683fc3912cb542f19906c83bcc1a52132556427170b2"
                        },
                        {
                            "type": "file",
                            "_comment": "NOTE: This commit SHA is pinned during release via ./release.sh",
                            "url": "https://github.com/tesseract-ocr/tessdata_fast/raw/main/ita.traineddata",
                            "sha256": "b8f89e1e785118dac4d51ae042c029a64edb5c3ee42ef73027a6d412748d8827"
                        }
                    ]
                }
            ]
        },

        {
            "name": "libportal",
            "buildsystem": "meson",
            "builddir": true,
            "config-opts": [
                "-Ddocs=false",
                "-Dtests=false",
                "-Dvapi=false",
                "-Dintrospection=true",
                "-Dbackend-gtk3=disabled",
                "-Dbackend-gtk4=enabled",
                "-Dbackend-qt5=disabled"
            ],
            "cleanup": [ "/include", "/lib/pkgconfig", "*.la" ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/flatpak/libportal.git",
                    "tag": "0.9.1",
                    "commit": "8f5dc8d192f6e31dafe69e35219e3b707bde71ce",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 193688,
                        "stable-only": true,
                        "tag-template": "$version"
                    }
                }
            ]
        },

        {
            "name": "zbar",
            "buildsystem": "autotools",
            "cleanup": [ "/bin", "/include", "/lib/pkgconfig", "*.la" ],
            "config-opts": [
                "--disable-static",
                "--without-gtk",
                "--without-python",
                "--without-imagemagick",
                "--without-dbus",
                "--without-qt",
                "--without-x",
                "--disable-video",
                "--disable-doc",
                "--with-introspection=no"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/mchehab/zbar.git",
                    "tag": "0.23.93",
                    "commit": "bb05ec54eec57f8397cb13fb9161372a281a1219",
                    "x-checker-data": {
                        "type": "git",
                        "tag-pattern": "^([\\d.]+)$"
                    }
                },
                {
                    "type": "shell",
                    "commands": [
                        "autoreconf -vfi",
                        "sed -i 's/lpthread/pthread/g' configure"
                    ]
                }
            ]
        },

        {
            "name": "blueprint-compiler",
            "buildsystem": "meson",
            "cleanup": [ "*" ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://gitlab.gnome.org/jwestman/blueprint-compiler.git",
                    "tag": "v0.16.0",
                    "commit": "04ef0944db56ab01307a29aaa7303df6067cb3c0",
                    "x-checker-data": {
                        "type": "git",
                        "tag-pattern": "^v([\\d.]+)$",
                        "tag-template": "v$version"
                    }
                }
            ]
        },

        {
            "name": "python3-pillow",
            "buildsystem": "simple",
            "build-commands": [
                "pip3 install --no-deps --no-build-isolation --prefix=/app --root-user-action=ignore --ignore-installed ."
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/python-pillow/Pillow.git",
                    "tag": "11.0.0",
                    "commit": "204aae6682fc936f5350b3fe70335776f81480a7",
                    "x-checker-data": {
                        "type": "pypi",
                        "name": "Pillow",
                        "tag-template": "$version"
                    }
                }
            ]
        },

        {
            "name": "python3-pytesseract",
            "buildsystem": "simple",
            "build-commands": [
                "pip3 install --no-deps --no-build-isolation --prefix=/app --root-user-action=ignore --ignore-installed ."
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/madmaze/pytesseract.git",
                    "tag": "v0.3.13",
                    "commit": "bb128f3ab846e4144d1e7529e37801554d5aef75",
                    "x-checker-data": {
                        "type": "pypi",
                        "name": "pytesseract",
                        "tag-template": "v$version"
                    }
                }
            ]
        },

        {
            "name": "python3-gTTS",
            "buildsystem": "simple",
            "build-commands": [
                "pip3 install --no-deps --no-build-isolation --prefix=/app --root-user-action=ignore --ignore-installed ."
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/pndurette/gTTS.git",
                    "tag": "v2.5.1",
                    "commit": "5cdaebfa7ad6856b051974d155e61ebfdfb0ab45",
                    "x-checker-data": {
                        "type": "pypi",
                        "name": "gTTS",
                        "tag-template": "v$version"
                    }
                }
            ]
        },

        {
            "name": "python3-dateutil",
            "buildsystem": "simple",
            "build-commands": [
                "pip3 install --no-deps --no-build-isolation --prefix=/app --root-user-action=ignore --ignore-installed setuptools_scm-7.1.0-py3-none-any.whl",
                "pip3 install --no-deps --no-build-isolation --prefix=/app --root-user-action=ignore --ignore-installed ."
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/dateutil/dateutil.git",
                    "tag": "2.9.0.post0",
                    "commit": "1ae807774053c071acc9e7d3d27778fba0a7773e",
                    "x-checker-data": {
                        "type": "pypi",
                        "name": "python-dateutil",
                        "tag-template": "$version"
                    }
                },
                {
                    "type": "file",
                    "url": "https://files.pythonhosted.org/packages/1d/66/8f42c941be949ef2b22fe905d850c794e7c170a526023612aad5f3a121ad/setuptools_scm-7.1.0-py3-none-any.whl",
                    "sha256": "73988b6d848709e2af142aa48c986ea29592bbcfca5375678064708205253d8e"
                }
            ]
        },

        {
            "name": "python3-loguru",
            "buildsystem": "simple",
            "build-commands": [
                "pip3 install --no-deps --no-build-isolation --prefix=/app --root-user-action=ignore --ignore-installed ."
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/Delgan/loguru.git",
                    "tag": "0.7.2",
                    "commit": "e1f48c91cf2646b6429020f784881cd200663114",
                    "x-checker-data": {
                        "type": "pypi",
                        "name": "loguru",
                        "tag-template": "$version"
                    }
                }
            ]
        },

        {
            "name": "python3-pyzbar",
            "buildsystem": "simple",
            "build-commands": [
                "pip3 install --no-deps --no-build-isolation --prefix=/app --root-user-action=ignore --ignore-installed ."
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/NaturalHistoryMuseum/pyzbar.git",
                    "tag": "v0.1.9",
                    "commit": "ff2892666fa7cd305f0a95f9808159809c6fc222",
                    "x-checker-data": {
                        "type": "pypi",
                        "name": "pyzbar",
                        "tag-template": "$version"
                    }
                }
            ]
        },

        {
            "name": "python3-urllib3",
            "buildsystem": "simple",
            "build-commands": [
                "pip3 install --no-deps --no-build-isolation --prefix=/app --root-user-action=ignore --ignore-installed urllib3-2.2.3-py3-none-any.whl"
            ],
            "sources": [
                {
                    "type": "file",
                    "url": "https://files.pythonhosted.org/packages/ce/d9/5f4c13cecde62396b0d3fe530a50ccea91e7dfc1ccf0e09c228841bb5ba8/urllib3-2.2.3-py3-none-any.whl",
                    "sha256": "ca899ca043dcb1bafa3e262d73aa25c465bfb49e0bd9dd5d59f1d0acba2f8fac"
                }
            ]
        },

        {
            "name": "python3-requests",
            "buildsystem": "simple",
            "build-commands": [
                "pip3 install --no-deps --no-build-isolation --prefix=/app --root-user-action=ignore --ignore-installed certifi-2024.8.30-py3-none-any.whl",
                "pip3 install --no-deps --no-build-isolation --prefix=/app --root-user-action=ignore --ignore-installed charset_normalizer-3.4.0-py3-none-any.whl",
                "pip3 install --no-deps --no-build-isolation --prefix=/app --root-user-action=ignore --ignore-installed idna-3.10-py3-none-any.whl",
                "pip3 install --no-deps --no-build-isolation --prefix=/app --root-user-action=ignore --ignore-installed ."
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/psf/requests.git",
                    "tag": "v2.32.3",
                    "commit": "0e322af87745eff34caffe4df68456ebc20d9068",
                    "x-checker-data": {
                        "type": "pypi",
                        "name": "requests",
                        "tag-template": "v$version"
                    }
                },
                {
                    "type": "file",
                    "url": "https://files.pythonhosted.org/packages/12/90/3c9ff0511d6c0f0b0c35e28b3851fbbac547d3405f21cfc44ab9e44e3d9/certifi-2024.8.30-py3-none-any.whl",
                    "sha256": "922820b53db7a7257ffbda3f597266d435245903d80737e34f8a45ff3e3230d8"
                },
                {
                    "type": "file",
                    "url": "https://files.pythonhosted.org/packages/bf/a0/188f223c19d8a96f7f8c05d77a2d2c729c6cb9b6987cbf0403f0f63983ee/charset_normalizer-3.4.0-py3-none-any.whl",
                    "sha256": "fe9f97feb71aa9896b81973a7bbada8c49501dc73e58a10fcef6663af95e5079"
                },
                {
                    "type": "file",
                    "url": "https://files.pythonhosted.org/packages/76/c6/c88e60db7e0c962a2f044e3d8435f8b1c5e9e1c2b9e2b5e5d5f8e2f3a4b5/idna-3.10-py3-none-any.whl",
                    "sha256": "946d195a0d259cbba61165e88e65941f16e9b36ea6ddb97f00452bae8b1287d3"
                }
            ]
        },

        {
            "name": "anura",
            "builddir": true,
            "buildsystem": "meson",
            "build-options": {
                "env": {
                    "GI_TYPELIB_PATH": "/app/lib/girepository-1.0:/usr/lib/girepository-1.0",
                    "LD_LIBRARY_PATH": "/app/lib"
                }
            },
            "sources": [
                {
                    "type": "dir",
                    "path": ".."
                }
            ]
        }
    ]
}
