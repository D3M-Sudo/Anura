                "pip3 install --no-deps --no-build-isolation --prefix=/app --root-user-action=ignore --ignore-installed packaging-24.2-py3-none-any.whl",
                "pip3 install --no-deps --no-build-isolation --prefix=/app --root-user-action=ignore --ignore-installed pluggy-1.5.0-py3-none-any.whl",
                "pip3 install --no-deps --no-build-isolation --prefix=/app --root-user-action=ignore --ignore-installed trove_classifiers-2026.4.28.13-py3-none-any.whl",
                "pip3 install --no-deps --no-build-isolation --prefix=/app --root-user-action=ignore --ignore-installed hatchling-1.27.0-py3-none-any.whl",
                "pip3 install --no-deps --no-build-isolation --prefix=/app --root-user-action=ignore --ignore-installed ."
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/urllib3/urllib3.git",
                    "tag": "2.2.3",
                    "commit": "2458bfcd3dacdf6c196e98d077fc6bb02a5fc1df",
