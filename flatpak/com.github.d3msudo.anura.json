                        "tag-template": "$version"
                    }
                }
            ]
        },

        {
            "name": "python3-pyzbar",
            "buildsystem": "simple",
            "build-commands": [
                "pip3 install --no-deps --no-build-isolation --prefix=/app --root-user-action=ignore --ignore-installed ."
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/NaturalHistoryMuseum/pyzbar.git",
