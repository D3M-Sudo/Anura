{
    "app-id": "com.github.d3msudo.anura",
    "runtime": "org.gnome.Platform",
    "runtime-version": "50",
    "sdk": "org.gnome.Sdk",
    "command": "anura",
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=dri",
        "--filesystem=xdg-run/format-status:ro"
    ],
    "cleanup": [
        "/include",
        "/lib/pkgconfig",
        "/share/aclocal",
        "/share/pkgconfig",
        "*.la",
        "*.a"
    ],
    "modules": [
        {
            "name": "zbar",
            "buildsystem": "autotools",
            "cleanup": [
                "/bin"
            ],
            "config-opts": [
                "--disable-static",
                "--without-gtk",
                "--without-python",
                "--without-imagemagick",
                "--without-dbus",
                "--without-qt",
                "--without-x",
                "--disable-video",
                "--disable-doc",
                "--with-introspection=no"
            ],
            "post-install": [
                "install -Dm0644 LICENSE $FLATPAK_DEST/share/licenses/com.github.d3msudo.anura/zbar/LICENSE"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/mchehab/zbar.git",
                    "tag": "0.23.93",
                    "commit": "bb05ec54eec57f8397cb13fb9161372a281a1219",
                    "x-checker-data": {
                        "type": "git",
                        "tag-pattern": "^([\\d.]+)$"
                    }
                },
                {
                    "type": "shell",
                    "commands": [
                        "sed -i 's/AC_CHECK_LIB(\\[pthread\\], \\[main\\],/AC_CHECK_LIB([c], [pthread_create],/g' configure.ac",
                        "autoreconf -vfi"
                    ]
                }
            ]
        },
        {
            "name": "libtiff",
            "cleanup": [
                "/share/doc",
                "/share/man"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://download.osgeo.org/libtiff/tiff-4.6.0.tar.gz",
                    "sha256": "88b3979e6d5c7e32b50d7ec72fb15af724f6ab2cbf7e10880c360a77e4b5d99a"
                }
            ]
        },
        {
            "name": "leptonica",
            "buildsystem": "autotools",
            "cleanup": [
                "/bin"
            ],
            "config-opts": [
                "--with-libtiff",
                "--with-zlib"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/DanBloomberg/leptonica/releases/download/1.84.1/leptonica-1.84.1.tar.gz",
                    "sha256": "2b3e1254b1cca381e77c819b59ca99774ff43530209b9aeb511e1d46588a64f6"
                }
            ]
        },
        {
            "name": "tesseract",
            "buildsystem": "autotools",
            "cleanup": [
                "/bin",
                "/share/tessdata"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/tesseract-ocr/tesseract/archive/refs/tags/5.3.4.tar.gz",
                    "sha256": "141afc12b34a14bb691a939b4b122db0d51bd38feda7f41696822bacea7710c7"
                }
            ]
        },
        {
            "name": "tessdata-ita",
            "buildsystem": "simple",
            "build-commands": [
                "install -Dm0644 ita.traineddata $FLATPAK_DEST/share/tessdata/ita.traineddata"
            ],
            "sources": [
                {
                    "type": "file",
                    "url": "https://github.com/tesseract-ocr/tessdata_fast/raw/main/ita.traineddata",
                    "sha256": "b8f89e1e785118dac4d51ae042c029a64edb5c3ee42ef73027a6d412748d8827"
                }
            ]
        },
        {
            "name": "anura",
            "buildsystem": "meson",
            "sources": [
                {
                    "type": "dir",
                    "path": ".."
                }
            ]
        }
    ]
}
