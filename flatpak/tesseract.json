{
    "name": "tesseract",
    "config-opts": [
        "--disable-static",
        "--disable-graphics",
        "--enable-legacy"
    ],
    "cleanup": [
        "/bin/tesseract",
        "/include",
        "/lib/pkgconfig",
        "*.la"
    ],
    "sources": [
        {
            "type": "git",
            "url": "https://github.com/tesseract-ocr/tesseract.git",
            "tag": "5.5.0",
            "x-checker-data": {
                "type": "git",
                "tag-pattern": "^v?([0-9]+(\\.[0-9]+)+)$"
            }
        }
    ],
    "post-install": [
        "chmod +x /app/bin/tesseract"
    ]
}
